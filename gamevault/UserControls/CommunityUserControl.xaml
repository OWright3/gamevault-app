<UserControl x:Class="gamevault.UserControls.CommunityUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"     
             xmlns:conv="clr-namespace:gamevault.Converter"
             xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             xmlns:local="clr-namespace:gamevault.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded" KeyDown="ReloadUser_Clicked" Focusable="True" IsVisibleChanged="UserControl_IsVisibleChanged">
    <UserControl.Resources>
        <conv:PermissionRoleToVisibilityConverter x:Key="roleToVisConv"/>
        <conv:UrlImageConverter x:Key="urlImgConv"/>
        <conv:GameStateColorConverter x:Key="gameStateColorConv"/>
        <conv:GameStateDescriptionConverter x:Key="gameStateDescConv"/>
        <conv:GameTimeConverter x:Key="gameTimeConv"/>
        <conv:UTCtoLocalTimeConverter x:Key="UtcTimeConv"/>
        <conv:InverseNullConverter x:Key="inverseNullConv"/>

        <Storyboard x:Key="SkeletonLoadingAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.OpacityMask).(LinearGradientBrush.GradientStops)[0].Offset"
                             From="-1" To="2" Duration="0:0:1.5" RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.OpacityMask).(LinearGradientBrush.GradientStops)[1].Offset"
                             From="-0.5" To="2.5" Duration="0:0:1.5" RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.OpacityMask).(LinearGradientBrush.GradientStops)[2].Offset"
                             From="0" To="3" Duration="0:0:1.5" RepeatBehavior="Forever" />
        </Storyboard>

        <Style x:Key="SkeletonBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFEFEFEF"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="OpacityMask">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#02FFFFFF" Offset="-1"/>
                        <GradientStop Color="#FFFFFFFF" Offset="-0.5"/>
                        <GradientStop Color="#02FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource MahApps.Brushes.ThemeBackground2}" Grid.Row="0">
            <TextBlock Text="Community" FontSize="35" Margin="20,0,0,0" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
        </Border>

        <Grid Grid.Row="1" ClipToBounds="True">
            <local:CacheImage ImageCacheType="UserBackground"
                              Data="{Binding Path=CurrentShownUser}"
                              Stretch="UniformToFill"/>

            <Grid Panel.ZIndex="1" Background="{DynamicResource MahApps.Brushes.ThemeBackground}" IsVisibleChanged="LoadingPlaceholder_IsVisibleChanged">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LoadingUser}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="#A0000000"
                        CornerRadius="12"
                        Margin="20"
                        MaxWidth="1100"
                        HorizontalAlignment="Center"/>
                <StackPanel x:Name="LoadingPlaceholder"
                            MaxWidth="1100"
                            Margin="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Height="150" Margin="0,10,0,15">
                        <Border Style="{StaticResource SkeletonBorderStyle}" Height="130" Width="130" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Top" Margin="0,10,0,0">
                            <Border Style="{StaticResource SkeletonBorderStyle}" Height="24" Width="220" Margin="0,0,0,8"/>
                            <Border Style="{StaticResource SkeletonBorderStyle}" Height="24" Width="140"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Style="{StaticResource SkeletonBorderStyle}" Height="75" Width="75" Margin="0,0,10,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <Border Style="{StaticResource SkeletonBorderStyle}" Height="20" Width="260" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SkeletonBorderStyle}" Height="18" Width="190"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Style="{StaticResource SkeletonBorderStyle}" Height="75" Width="75" Margin="0,0,10,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <Border Style="{StaticResource SkeletonBorderStyle}" Height="20" Width="260" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SkeletonBorderStyle}" Height="18" Width="190"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border Background="#A0000000"
                    CornerRadius="12"
                    Margin="20"
                    MaxWidth="1100"
                    HorizontalAlignment="Center"/>

            <DockPanel LastChildFill="True"
                       Background="Transparent"
                       Margin="24"
                       MaxWidth="1100"
                       HorizontalAlignment="Stretch">
                <Grid DockPanel.Dock="Top" Height="175" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ComboBox x:Name="uiSelectUser"
                              Grid.Column="1"
                              Grid.Row="1"
                              FontWeight="Bold"
                              ItemsSource="{Binding Users}"
                              DisplayMemberPath="Username"
                              HorizontalAlignment="Left"
                              Width="220"
                              Height="0"
                              SelectionChanged="Users_SelectionChanged"/>

                    <local:CacheImage Grid.Column="0"
                                      Grid.RowSpan="2"
                                      Height="150"
                                      Width="150"
                                      Stretch="Fill"
                                      ImageCacheType="UserAvatar"
                                      CornerRadius="10"
                                      Data="{Binding Path=CurrentShownUser}"/>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Path=CurrentShownUser.FirstName}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <Border Background="{DynamicResource MahApps.Brushes.Accent}"
                                Width="120"
                                Height="32"
                                Padding="5"
                                CornerRadius="5"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding Path=CurrentShownUser.Role}"
                                       Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Style="{StaticResource ButtonWrapper}"
                                x:Name="uiBtnReloadUser"
                                Cursor="Hand"
                                Width="30"
                                Height="30"
                                ToolTip="Reload current user (F5)"
                                Click="ReloadUser_Clicked">
                            <Grid Style="{DynamicResource HoverEffect}" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                                <Path Data="{StaticResource IconReload}" Fill="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                                <Grid.RenderTransform>
                                    <ScaleTransform/>
                                </Grid.RenderTransform>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ButtonWrapper}"
                                VerticalAlignment="Top"
                                Visibility="{Binding SelectedIndex,ElementName=uiSelectUser,Converter={StaticResource roleToVisConv}}"
                                Cursor="Hand"
                                Width="30"
                                Height="30"
                                Margin="8,0,0,0"
                                Click="UserEdit_Clicked">
                            <Grid Style="{DynamicResource HoverEffect}" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                                <Path Data="{StaticResource IconEditUser}" Fill="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                                <Grid.RenderTransform>
                                    <ScaleTransform/>
                                </Grid.RenderTransform>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <ComboBox x:Name="uiSortBy"
                              Grid.Column="2"
                              Grid.Row="1"
                              Width="170"
                              ItemsSource="{Binding SortBy}"
                              SelectionChanged="SortBy_SelectionChanged"/>
                </Grid>

                <ScrollViewer x:Name="uiProgressScrollView"
                              Margin="10,0,10,20"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <ItemsControl ItemsSource="{Binding Path=UserProgresses}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel LastChildFill="True" Height="108" Margin="0,0,0,10">
                                        <Button Style="{StaticResource ButtonWrapper}" Width="92" Height="92" Cursor="Hand" Click="GameImage_Click">
                                            <local:CacheImage ImageCacheType="GameCover" Data="{Binding}" CornerRadius="4"/>
                                        </Button>
                                        <Grid Margin="10,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="48"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="TextBlock.Text" Value="{Binding Path=Game.Metadata.Title}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Path=Game.Metadata.Title}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="{Binding Path=Game.Title}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Path=Game.DeletedAt,Converter={StaticResource inverseNullConv}}" Value="False">
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <TextBlock Text="State: " FontSize="14"/>
                                                <TextBlock Text="{Binding Path=State,Converter={StaticResource gameStateDescConv}}"
                                                           Foreground="{Binding Path=State,Converter={StaticResource gameStateColorConv}}"
                                                           FontSize="14" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10,0,10,0">
                                                <TextBlock Text="{Binding Path=MinutesPlayed,StringFormat='{}Time played: {0}',Converter={StaticResource gameTimeConv}}" FontSize="14">
                                                    <TextBlock.ToolTip>
                                                        <TextBlock Text="{Binding Path=MinutesPlayed,StringFormat='{}{0} min'}"/>
                                                    </TextBlock.ToolTip>
                                                </TextBlock>
                                                <TextBlock FontSize="14" DataContext="{Binding Path=LastPlayedAt,Converter={StaticResource UtcTimeConv}}" Text="{Binding StringFormat='{}Last played: {0:dd.MM.yyyy}'}">
                                                    <TextBlock.ToolTip>
                                                        <TextBlock Text="{Binding StringFormat='{}{0:HH:mm:ss&#x0a;dd.MM.yyyy}'}"/>
                                                    </TextBlock.ToolTip>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Grid.RowSpan="2"
                                                    Style="{StaticResource ButtonWrapper}"
                                                    Visibility="{Binding SelectedIndex,ElementName=uiSelectUser,Converter={StaticResource roleToVisConv}}"
                                                    Cursor="Hand"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right"
                                                    Height="30"
                                                    Width="30"
                                                    Click="DeleteProgress_Click">
                                                <Grid Style="{DynamicResource HoverEffect}" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                                                    <Path Data="{StaticResource IconTrash}" Fill="IndianRed" Margin="0,0,-20,-20">
                                                        <Path.RenderTransform>
                                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                    <Grid.RenderTransform>
                                                        <ScaleTransform/>
                                                    </Grid.RenderTransform>
                                                </Grid>
                                            </Button>
                                        </Grid>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No games played yet" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,30,5,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UserProgresses.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
